# Copy to .env and adjust before running: docker compose up --build

# SQL Server SA password (must meet SQL Server complexity requirements)
MSSQL_SA_PASSWORD=Your_password123!

# JWT signing key (minimum 32 characters)
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-characters-1234567890

# Host port for the web application (API + Angular SPA)
API_HTTP_PORT=8080

# Optional: host port for SQL Server when using docker-compose.dev.yml
MSSQL_PORT=1433

# Database files under ./data/ are gitignored. Docker named volumes also stay outside the repo.
# Unit tests use EF Core InMemory — no files are written to disk.

# For local `dotnet run` against docker-compose.dev.yml database, set this env var:
# ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=LiberationFleetDb;User Id=sa;Password=Your_password123!;TrustServerCertificate=True;Encrypt=False

# LiveKit (voice) — must match infrastructure/livekit.yaml keys and appsettings LiveKit section
# LiveKit__Host=ws://localhost:7880
# LiveKit__ApiKey=devkey
# LiveKit__ApiSecret=secretsecretsecretsecretsecretsecret12
# LiveKit__TokenTtlMinutes=360
#
# Start voice infra: docker compose -f docker-compose.dev.yml up -d livekit coturn
# See docs/LIVEKIT-SETUP.md
